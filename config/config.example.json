{
  "agent": {
    "name": "Personal AI Agent",
    "version": "1.0.0",
    "personality": {
      "style": "helpful",
      "tone": "friendly",
      "verbosity": "balanced"
    },
    "capabilities": {
      "web_search": false,
      "file_operations": true,
      "code_execution": false,
      "api_calls": true
    }
  },
  "nlp": {
    "provider": "local",
    "model": "basic",
    "language": "en",
    "sentiment_analysis": true,
    "intent_recognition": true,
    "entity_extraction": true
  },
  "memory": {
    "memory_dir": "data/memory",
    "max_context_length": 10,
    "memory_retention_days": 30,
    "enable_long_term_memory": true,
    "enable_short_term_memory": true
  },
  "formatting": {
    "max_response_length": 2000,
    "use_markdown": false,
    "include_metadata": false,
    "response_style": "conversational"
  },
  "integrations": {
    "openai": {
      "enabled": false,
      "api_key": "your-openai-api-key-here",
      "model": "gpt-3.5-turbo",
      "max_tokens": 1000
    },
    "anthropic": {
      "enabled": false,
      "api_key": "your-anthropic-api-key-here",
      "model": "claude-3-sonnet-20240229",
      "max_tokens": 1000
    },
    "web_search": {
      "enabled": false,
      "provider": "duckduckgo",
      "max_results": 5
    },
    "database": {
      "type": "sqlite",
      "path": "data/agent.db"
    }
  },
  "security": {
    "enable_content_filtering": true,
    "enable_rate_limiting": true,
    "max_requests_per_minute": 60,
    "allowed_file_extensions": [".txt", ".md", ".json", ".py", ".js", ".html", ".css"],
    "blocked_domains": [],
    "enable_logging": true
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file": "logs/agent.log",
    "max_file_size": "10MB",
    "backup_count": 5
  },
  "server": {
    "host": "localhost",
    "port": 8000,
    "enable_cors": true,
    "enable_docs": true
  },
  "features": {
    "voice_input": false,
    "voice_output": false,
    "gui_interface": false,
    "web_interface": true,
    "cli_interface": true,
    "auto_save_conversations": true,
    "context_awareness": true,
    "learning_mode": true
  }
}